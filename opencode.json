{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "tailwindcss": {
      "command": ["npx", "tailwindcss-language-server", "--stdio"],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".mts",
        ".cts",
        ".vue",
        ".svelte",
        ".astro"
      ]
    }
  }
}
